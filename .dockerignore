# Keep the build context lean and reproducible.
#
# IMPORTANT: .git is excluded by design. The Dockerfile cannot run
# `git submodule update` (no .git inside the container), so we require
# lib/aster/ to be pre-populated on the host. See the build helper.

# Local build dirs — never ship build artefacts
build/
build_*/
build-*/

# Aster (RocksDB fork) build artefacts on the host. These contain .d
# files with absolute paths (e.g. /usr/local/include on macOS) that
# would mismatch inside the linux container and break `make aster`.
# The container does its own clean build.
lib/aster/**/*.o
lib/aster/**/*.d
lib/aster/**/*.a
lib/aster/**/*.so
lib/aster/**/*.dylib
# Cached platform detection from a host build. A macOS-generated
# make_config.mk (PLATFORM=OS_MACOSX) copied into the linux build makes
# `make aster` skip build_detect_platform and compile a mismatched,
# truncated librocksdb.a -> undefined references at the final link.
# Exclude it so the container always re-detects its own platform.
lib/aster/make_config.mk

# Bench / dataset artefacts
data/sift*
data/*.fvecs
data/*.ivecs
data/*.tar.gz
data/sift/
run/
output.txt

# Editor / OS junk
.DS_Store
.cache/
.claude/
.vscode/
.idea/

# Git internals — submodule init must happen on the host
.git/
.gitignore
.gitmodules

# Local notes / scratch
DEBUG_REPORT.md
HEAP_CORRUPTION_REPORT.md
PHASE1_COMPILER_FLAGS.md
debug_malloc.log
CLAUDE.md

# Docs are not needed in the runtime image and would bloat context
docs/

# Python venvs / wheels
*.egg-info/
__pycache__/
*.pyc
.venv/

# Pre-built static libs lying around
lib/libastervec.a
libmalloc_shim.*
malloc_shim.*

# Test binary scratch
test/astervec_test
